    }
}

programa {
    funcao inicio() {
        inteiro n, a, b, prox, i
        a = 0
        b = 1
        
        escreva("Digite quantos termos da sequência de Fibonacci deseja: ")
        leia(n)
        
        escreva(a, " ", b, " ")
        
        para (i = 3; i <= n; i++) {
            prox = a + b
            escreva(prox, " ")
            a = b
            b = prox
        }
        escreva("\n")
    }
}

programa {
    funcao inicio() {
        inteiro num, invertido, resto
        
        escreva("Digite um número: ")
        leia(num)
        
        invertido = 0
        
        enquanto (num > 0) {
            resto = num % 10
            invertido = (invertido * 10) + resto
            num = num / 10
        }
        
        escreva("O número invertido é: ", invertido, "\n")
    }
}

programa {
    funcao inicio() {
        real base, resultado
        inteiro expoente, i
        
        escreva("Digite a base: ")
        leia(base)
        
        escreva("Digite o expoente: ")
        leia(expoente)
        
        resultado = 1
        
        para (i = 1; i <= expoente; i++) {
            resultado = resultado * base
        }
        
        escreva(base, " elevado a ", expoente, " é: ", resultado, "\n")
    }
}

programa {
    funcao inicio() {
        inteiro a, b, mdc
        
        escreva("Digite o primeiro número: ")
        leia(a)
        escreva("Digite o segundo número: ")
        leia(b)
        
        enquanto (b != 0) {
            mdc = a % b
            a = b
            b = mdc
        }
        
        escreva("O MDC é: ", a, "\n")
    }
}

programa {
    funcao inicio() {
        inteiro a, b, aux_a, aux_b, mmc
        
        escreva("Digite o primeiro número: ")
        leia(a)
        escreva("Digite o segundo número: ")
        leia(b)
        
        aux_a = a
        aux_b = b
        
        enquanto (aux_a != aux_b) {
            se (aux_a < aux_b) {
                aux_a = aux_a + a
            } senao {
                aux_b = aux_b + b
            }
        }
        
        mmc = aux_a
        escreva("O MMC é: ", mmc, "\n")
    }
}

programa {
	funcao inicio() {
		inteiro numero, soma, i

		escreva("Digite um número: ")
		leia(numero)

		soma = 0
		para (i = 1; i < numero; i++) {
			se (numero % i == 0) {
				soma = soma + i
			}
		}

		se (soma == numero) {
			escreva(numero, " é um número perfeito.\n")
		} senao {
			escreva(numero, " não é um número perfeito.\n")
		}
	}
}

programa {
	inclua biblioteca Util --> u
	
	funcao inicio() {
		inteiro numero_secreto, palpite

		// Gerar um número secreto aleatório entre 1 e 100
		numero_secreto = u.sorteia(1, 100)

		escreva("Adivinhe o número secreto entre 1 e 100: ")
		leia(palpite)

		// Enquanto o palpite estiver errado, continue perguntando
		enquanto (palpite != numero_secreto) { 
			se (palpite < numero_secreto) {
				escreva("Muito baixo! Tente novamente: ")
			} senao {
				escreva("Muito alto! Tente novamente: ")
			}
			leia(palpite)
		}

		escreva("Parabéns! Você adivinhou o número secreto: ", numero_secreto, ".\n")
	}
}
